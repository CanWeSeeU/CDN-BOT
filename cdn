# ── Main loop ─────────────────────────────────────────────────────────────────

main() {
    while true; do
        show_main_menu
        case "${MAIN_CHOICE}" in
            0)  echo ""; echo -e "  ${CYAN}Goodbye.${RESET}"; echo ""; exit 0 ;;
            1)  do_install            ;;
            2)  do_update             ;;
            3)  do_install_version    ;;
            4)  do_uninstall          ;;
            5)  do_service_manager    ;;
            6)  do_start              ;;
            7)  do_stop               ;;
            8)  do_restart            ;;
            9)  do_view_logs          ;;
            10) do_config_manager     ;;
            11) do_help               ;;
            *)  echo -e "  ${RED}Invalid option. Please enter a number between 0 and 11.${RESET}"; sleep 1 ;;
        esac
    done
}

main "$@"